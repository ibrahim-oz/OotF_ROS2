AFFIX_SERVER=192.168.137.110

# Share names on the SMB server
AFFIX_RESULTS_SHARE=images
AFFIX_ALL_IMAGES_SHARE=images_all
AFFIX_DB_SHARE=db

# Local mount targets used by the backend
AFFIX_RESULTS_MOUNT=/mnt/affix_images
AFFIX_ALL_IMAGES_MOUNT=/mnt/affix_all_images
AFFIX_DB_MOUNT=/mnt/affix_db

# SMB authentication
AFFIX_USERNAME=AFFIXENGINEERING242
AFFIX_PASSWORD=

# Optional mount flags
AFFIX_MOUNT_FLAGS=ro
# AFFIX_RESULTS_FLAGS=ro
# AFFIX_ALL_IMAGES_FLAGS=ro
# AFFIX_DB_FLAGS=ro

# Optional alternatives:
# AFFIX_PASSWORD_FILE=/etc/doosan_ipc/affix_smb.credentials
# AFFIX_SMB_VERSION=3.0
# AFFIX_UID=1000
# AFFIX_GID=1000
